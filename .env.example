# Neon Postgres — pooled connection, used by the running app at runtime
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/job-tracker?sslmode=require"

# Neon Postgres — unpooled/direct connection, used only by the Prisma CLI (migrate/studio)
DIRECT_URL="postgresql://user:password@ep-example.region.aws.neon.tech/job-tracker?sslmode=require"

# Generate with: npx auth secret
AUTH_SECRET=""

# GitHub OAuth App (Settings -> Developer settings -> OAuth Apps)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google OAuth Client (Google Cloud Console -> APIs & Services -> Credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
